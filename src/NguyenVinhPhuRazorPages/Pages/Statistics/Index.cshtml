@page
@model FUNewsManagement.RazorPages.Pages.Statistics.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Statistics";
}

<h2>News Statistics Report</h2>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Start Date</label>
            <input type="date" class="form-control" asp-for="StartDate" />
        </div>
        <div class="col-md-4">
            <label class="form-label">End Date</label>
            <input type="date" class="form-control" asp-for="EndDate" />
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Generate Report</button>
        </div>
    </div>
</form>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5 class="card-title">Total Articles</h5>
                <h2>@Model.TotalArticles</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5 class="card-title">Active Articles</h5>
                <h2>@Model.ActiveArticles</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-secondary text-white">
            <div class="card-body">
                <h5 class="card-title">Inactive Articles</h5>
                <h2>@Model.InactiveArticles</h2>
            </div>
        </div>
    </div>
</div>

<h4>News Articles (Sorted by Created Date Descending)</h4>
<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Headline</th>
            <th>Category</th>
            <th>Created By</th>
            <th>Created Date</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var news in Model.NewsArticles)
        {
            <tr>
                <td>@news.NewsArticleID</td>
                <td>@news.Headline</td>
                <td>@news.Category?.CategoryName</td>
                <td>@news.CreatedBy?.AccountName</td>
                <td>@news.CreatedDate?.ToString("yyyy-MM-dd")</td>
                <td>
                    @if (news.NewsStatus == true)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.NewsArticles.Any())
{
    <div class="alert alert-info">No news articles found in the selected date range.</div>
}
