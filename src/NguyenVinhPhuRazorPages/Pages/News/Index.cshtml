@page
@model FUNewsManagement.RazorPages.Pages.News.IndexModel
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    Layout = "_Layout";
    ViewData["Title"] = "News Management";
    var role = HttpContextAccessor.HttpContext?.Session.GetString("AccountRole");
    var isStaff = role == "1";
    var isAdmin = role == "0";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>News Articles</h2>
    @if (isStaff)
    {
        <a class="btn btn-primary" href="#" onclick="showCreateModal(); return false;">Create New News</a>
    }
</div>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <input type="text" class="form-control" placeholder="Search by title or headline..." 
                   name="SearchTerm" value="@Model.SearchTerm" />
        </div>
        <div class="col-md-3">
            <select class="form-select" name="CategoryId">
                <option value="">All Categories</option>
            </select>
        </div>
        @if (isStaff || isAdmin)
        {
            <div class="col-md-3">
                <select class="form-select" name="Status">
                    <option value="">All Status</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
        }
        <div class="col-md-2">
            <button type="submit" class="btn btn-secondary w-100">Filter</button>
        </div>
    </div>
</form>

<div class="row" id="newsList">
    @foreach (var news in Model.NewsArticles)
    {
        <div class="col-md-6 mb-4 news-item">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="badge bg-info">@news.Category?.CategoryName</span>
                    @if (news.NewsStatus == true)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </div>
                <div class="card-body">
                    <h5 class="card-title">@news.Headline</h5>
                    @if (!string.IsNullOrEmpty(news.NewsTitle))
                    {
                        <h6 class="card-subtitle mb-2 text-muted">@news.NewsTitle</h6>
                    }
                    <p class="card-text text-truncate">@(news.NewsContent?.Length > 200 ? news.NewsContent.Substring(0, 200) + "..." : news.NewsContent)</p>
                    <div class="mb-2">
                        @if (news.NewsTags.Any())
                        {
                            @foreach (var tag in news.NewsTags)
                            {
                                <span class="badge bg-secondary me-1">@tag.Tag?.TagName</span>
                            }
                        }
                    </div>
                    <small class="text-muted">
                        By @news.CreatedBy?.AccountName | @news.CreatedDate?.ToString("yyyy-MM-dd")
                    </small>
                </div>
                <div class="card-footer">
                    @if (isStaff || isAdmin)
                    {
                        <button class="btn btn-sm btn-primary" onclick="showEditModal('@news.NewsArticleID'); return false;">Edit</button>
                        <button class="btn btn-sm btn-danger" onclick="confirmDelete('@news.NewsArticleID'); return false;">Delete</button>
                    }
                    <a class="btn btn-sm btn-info" href="/News/Details/@news.NewsArticleID">Details</a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.NewsArticles.Any())
{
    <div class="alert alert-info">No news articles found.</div>
}

<div class="modal fade" id="newsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Create News</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="newsId" />
                <div class="mb-3">
                    <label class="form-label">Headline *</label>
                    <input type="text" class="form-control" id="headline" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">News Title</label>
                    <input type="text" class="form-control" id="newsTitle" />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Category *</label>
                        <select class="form-select" id="categoryId" required>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Status</label>
                        <select class="form-select" id="newsStatus">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">News Content *</label>
                    <textarea class="form-control" id="newsContent" rows="5" required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">News Source</label>
                    <input type="text" class="form-control" id="newsSource" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tags</label>
                    <div id="tagsContainer" class="border p-2 rounded">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveNews()">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this news article?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadTags() {
            const response = await fetch('/api/news/tags');
            const tags = await response.json();
            const container = document.getElementById('tagsContainer');
            container.innerHTML = tags.map(tag => 
                '<div class="form-check form-check-inline">' +
                '<input class="form-check-input tag-checkbox" type="checkbox" value="' + tag.tagID + '" id="tag' + tag.tagID + '">' +
                '<label class="form-check-label" for="tag' + tag.tagID + '">' + tag.tagName + '</label>' +
                '</div>'
            ).join('');
        }

        async function loadCategories() {
            const response = await fetch('/api/categories');
            const categories = await response.json();
            const select = document.getElementById('categoryId');
            select.innerHTML = categories.map(cat => 
                '<option value="' + cat.categoryID + '">' + cat.categoryName + '</option>'
            ).join('');
        }

        function showCreateModal() {
            document.getElementById('modalTitle').textContent = 'Create News';
            document.getElementById('newsId').value = '';
            document.getElementById('headline').value = '';
            document.getElementById('newsTitle').value = '';
            document.getElementById('newsContent').value = '';
            document.getElementById('newsSource').value = '';
            document.getElementById('newsStatus').value = 'true';
            document.querySelectorAll('.tag-checkbox').forEach(cb => cb.checked = false);
            loadTags();
            loadCategories();
            new bootstrap.Modal(document.getElementById('newsModal')).show();
        }

        async function showEditModal(id) {
            await loadTags();
            await loadCategories();
            const response = await fetch('/api/news/' + id);
            const news = await response.json();
            
            document.getElementById('modalTitle').textContent = 'Edit News';
            document.getElementById('newsId').value = news.newsArticleID;
            document.getElementById('headline').value = news.headline;
            document.getElementById('newsTitle').value = news.newsTitle || '';
            document.getElementById('newsContent').value = news.newsContent || '';
            document.getElementById('newsSource').value = news.newsSource || '';
            document.getElementById('categoryId').value = news.categoryID || '';
            document.getElementById('newsStatus').value = news.newsStatus ? 'true' : 'false';
            
            document.querySelectorAll('.tag-checkbox').forEach(cb => cb.checked = false);
            if (news.tags) {
                news.tags.forEach(t => {
                    const cb = document.getElementById('tag' + t.tagID);
                    if (cb) cb.checked = true;
                });
            }
            
            new bootstrap.Modal(document.getElementById('newsModal')).show();
        }

        async function saveNews() {
            const id = document.getElementById('newsId').value;
            const selectedTags = Array.from(document.querySelectorAll('.tag-checkbox:checked')).map(cb => parseInt(cb.value));
            
            const news = {
                headline: document.getElementById('headline').value,
                newsTitle: document.getElementById('newsTitle').value,
                newsContent: document.getElementById('newsContent').value,
                newsSource: document.getElementById('newsSource').value,
                categoryID: parseInt(document.getElementById('categoryId').value),
                newsStatus: document.getElementById('newsStatus').value === 'true',
                selectedTagIds: selectedTags
            };

            const url = id ? '/api/news/' + id : '/api/news';
            const method = id ? 'PUT' : 'POST';

            const response = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(news)
            });

            if (response.ok) {
                bootstrap.Modal.getInstance(document.getElementById('newsModal')).hide();
                location.reload();
            } else {
                alert('Error saving news');
            }
        }

        function confirmDelete(id) {
            console.log('Delete clicked for:', id);
            document.getElementById('confirmDeleteBtn').onclick = async () => {
                console.log('Confirm delete for:', id);
                const response = await fetch('/api/news/' + id, { method: 'DELETE' });
                console.log('Response status:', response.status);
                if (response.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                    location.reload();
                } else {
                    const result = await response.json();
                    alert('Error: ' + (result.error || 'Failed to delete'));
                }
            };
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        loadTags();
        loadCategories();
    </script>
}
