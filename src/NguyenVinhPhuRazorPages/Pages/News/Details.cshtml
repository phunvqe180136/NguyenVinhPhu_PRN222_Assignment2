@page
@model FUNewsManagement.RazorPages.Pages.News.DetailsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "News Details";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h3>@Model.NewsArticle?.Headline</h3>
            @if (!string.IsNullOrEmpty(Model.NewsArticle?.NewsTitle))
            {
                <h5 class="text-muted">@Model.NewsArticle.NewsTitle</h5>
            }
        </div>
        <div>
            @if (Model.NewsArticle?.NewsStatus == true)
            {
                <span class="badge bg-success">Active</span>
            }
            else
            {
                <span class="badge bg-secondary">Inactive</span>
            }
        </div>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <strong>Category:</strong> @Model.NewsArticle?.Category?.CategoryName
        </div>
        <div class="mb-3">
            <strong>Created by:</strong> @Model.NewsArticle?.CreatedBy?.AccountName
        </div>
        <div class="mb-3">
            <strong>Created date:</strong> @Model.NewsArticle?.CreatedDate?.ToString("yyyy-MM-dd HH:mm")
        </div>
        @if (Model.NewsArticle?.ModifiedDate.HasValue == true)
        {
            <div class="mb-3">
                <strong>Modified by:</strong> @Model.NewsArticle?.UpdatedBy?.AccountName (@Model.NewsArticle?.ModifiedDate?.ToString("yyyy-MM-dd HH:mm"))
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.NewsArticle?.NewsSource))
        {
            <div class="mb-3">
                <strong>Source:</strong> @Model.NewsArticle.NewsSource
            </div>
        }
        <div class="mb-3">
            <strong>Tags:</strong>
            @if (Model.NewsArticle?.NewsTags.Any() == true)
            {
                @foreach (var tag in Model.NewsArticle.NewsTags)
                {
                    <span class="badge bg-secondary me-1">@tag.Tag?.TagName</span>
                }
            }
            else
            {
                <span class="text-muted">No tags</span>
            }
        </div>
        <hr />
        <div class="news-content">
            @Html.Raw(Model.NewsArticle?.NewsContent?.Replace("\n", "<br />"))
        </div>
    </div>
    <div class="card-footer">
        <a class="btn btn-secondary" href="/">Back to List</a>
    </div>
</div>
